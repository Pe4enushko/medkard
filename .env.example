OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Postgres — store password as plain text here; special characters are URL-encoded in code
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medkard
POSTGRES_USER=medkard_user
POSTGRES_PASSWORD=

# Must match the embedding model output dimension (Qwen/Qwen3-Embedding-4B = 1024)
EMBEDDING_DIM=1024
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# Embedding provider: "openai" (AsyncOpenAI-compatible REST) or "st" (sentence-transformers, local)
EMBEDDING_PROVIDER=openai
EMBEDDING_BASE_URL=
