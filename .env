OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Postgres — store password as plain text here; special characters are URL-encoded in code
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medkard
POSTGRES_USER=medkard_user
POSTGRES_PASSWORD=

# Must match the embedding model output dimension (OpenAI text-embedding-3-small = 1536)
EMBEDDING_DIM=1536
